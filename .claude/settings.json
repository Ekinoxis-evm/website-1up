{
  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run build:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run start:*)",
      "Bash(npm install:*)",
      "Bash(npm list:*)",
      "Bash(npm audit:*)",
      "Bash(npm pkg:*)",
      "Bash(npx tsc:*)",
      "Bash(npx next:*)",
      "Bash(node_modules/.bin/next lint:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git tag:*)",
      "Bash(git:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "mcp__plugin_supabase_supabase__list_projects",
      "mcp__plugin_supabase_supabase__list_tables",
      "mcp__plugin_supabase_supabase__get_project_url",
      "mcp__plugin_supabase_supabase__get_publishable_keys",
      "mcp__plugin_supabase_supabase__apply_migration",
      "mcp__plugin_supabase_supabase__generate_typescript_types",
      "mcp__plugin_supabase_supabase__execute_sql",
      "mcp__plugin_supabase_supabase__list_migrations",
      "mcp__plugin_supabase_supabase__list_extensions",
      "mcp__plugin_supabase_supabase__get_logs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__privy-docs__search_privy_docs",
      "mcp__privy-docs__get_page_privy_docs",
      "WebFetch(domain:docs.privy.io)",
      "WebFetch(domain:ethskills.com)",
      "WebFetch(domain:supabase.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:tailwindcss.com)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-code-change.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_vercel_vercel__deploy_to_vercel",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-deploy.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/changelog-update.sh"
          }
        ]
      }
    ]
  }
}
